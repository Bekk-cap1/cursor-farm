# Скопируйте в .env и при необходимости измените.
# Можно положить тот же файл в родительскую папку (farm-platform/.env) — бэкенд читает оба: сначала корень монорепо, потом backend/.env (при совпадении имён переменных побеждает backend).
# Если в farm-platform/.env осталась строка OPENAI_API_KEY=crsr_… (шаблон Cursor) — удалите её или замените на реальный sk- или AIza…, иначе LLM будет «off».

JWT_SECRET=замените-на-длинную-случайную-строку
DATABASE_URL=sqlite:///./farm.db

# Регистрация по SMS / email: в демо код ещё и в JSON (debug_code); в проде — false
SMS_DEBUG_RETURN_CODE=true

# --- Отправка кода регистрации на почту (SMTP). Без этого письма не уходят (только debug_code в ответе при SMS_DEBUG_RETURN_CODE=true).
# Пример Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USE_TLS=true SMTP_USE_SSL=false
# SMTP_USER=ваш@gmail.com SMTP_PASSWORD=пароль_приложения (не обычный пароль) EMAIL_FROM=ваш@gmail.com
# Порт 465 (SSL): SMTP_PORT=465 SMTP_USE_SSL=true SMTP_USE_TLS=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
#
# --- Локально «как в Node» (MailHog / nodemailer → тот же SMTP) ---
# Поднимите Mailpit: из корня farm-platform выполните
#   docker compose --profile dev-mail up -d
# Затем в .env (и в farm-platform/.env для compose):
#   SMTP_HOST=mailpit
#   SMTP_PORT=1025
#   SMTP_USE_TLS=false
#   SMTP_USE_SSL=false
#   SMTP_USER=
#   SMTP_PASSWORD=
#   EMAIL_FROM=noreply@local.test
# Письма с кодом: http://127.0.0.1:8025
#
# Если бэкенд не в Docker, а Mailpit в Docker с пробросом 1025:1025:
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=1025
#   SMTP_USE_TLS=false

# Опционально: умный агент (иначе — правила + погода)
# OpenAI: ключ только вида sk-…
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# Google Gemini (ключ AIza… из AI Studio): либо GEMINI_API_KEY, либо тот же ключ в OPENAI_API_KEY — бэкенд распознает AIza и пойдёт в Gemini API (OpenAI-совместимый endpoint), не в api.openai.com
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Telegram admin notifications from the browser extension.
# Create a bot with BotFather, send one message to it, then put your admin chat id here.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=
