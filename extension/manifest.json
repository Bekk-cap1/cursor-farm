{
  "manifest_version": 3,
  "name": "Farm Platform Tools",
  "short_name": "Farm Tools",
  "version": "1.0.0",
  "description": "Cost calculator, market price monitoring, and PDF/Excel export for farmers. Works on every website.",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Farm Platform Tools"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {}
}
