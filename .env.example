# Скопируйте в .env рядом с docker-compose.yml (Coolify подставляет свой .env).

JWT_SECRET=замените-на-длинную-случайную-строку

# Если при деплое ошибка «Bind for 0.0.0.0:80 failed: port is already allocated» —
# на хосте уже слушает :80 (другой стек, системный nginx и т.д.). Укажите свободный порт:
HTTP_PORT=8080

# Опционально: ключ из https://platform.openai.com (начинается с sk-). Для Docker укажите здесь,
# рядом с docker-compose.yml — не только в backend/.env
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# CORS_ORIGINS_EXTRA=https://другой-фронт.example.com

# Код регистрации на email (бэкенд читает из этого .env или backend/.env):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-password
# EMAIL_FROM=you@gmail.com
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMS_DEBUG_RETURN_CODE=false
#
# Локальная почта (Mailpit, профиль dev-mail в docker-compose.yml):
# docker compose --profile dev-mail up -d
# SMTP_HOST=mailpit SMTP_PORT=1025 SMTP_USE_TLS=false SMTP_USE_SSL=false EMAIL_FROM=noreply@local.test
# UI: http://127.0.0.1:8025
